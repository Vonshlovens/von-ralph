#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

if [[ -x "$REPO_ROOT/ralph" ]]; then
  exec "$REPO_ROOT/ralph" taskq "$@"
fi

if command -v ralph >/dev/null 2>&1; then
  exec ralph taskq "$@"
fi

echo "error: could not find ralph binary (repo-local or PATH)" >&2
exit 1
