#!/usr/bin/env bash
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SELF_RALPH="$SCRIPT_DIR/$(basename "$0")"
if [[ -x "$SELF_RALPH" ]]; then
  export RALPH_BIN="${RALPH_BIN:-$SELF_RALPH}"
fi

if [[ "${1:-}" == "taskq" ]]; then
  shift
  if ! command -v python3 &>/dev/null; then
    echo "Error: python3 is required for 'ralph taskq'"
    exit 1
  fi
  exec python3 "$SCRIPT_DIR/scripts/ralph_taskq.py" "$@"
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq is not installed. Install it with: sudo apt install jq"
  exit 1
fi

DEFAULT_PROMPT='/tackle choose a todo. If you come across tasks that go out of scope of the todo, make new kanban todos.

Update specs if needed — they are the current source of truth. Rules:

1. NEVER delete planned feature descriptions, API designs, or architectural blueprints from specs. If something isn'\''t implemented yet, mark it as "Planned" — don'\''t remove it. The design detail is the whole point.

2. DO fix stale file paths, wrong component names, and inaccurate descriptions of *implemented* code.

3. If you touch a spec, clearly separate "Implemented" sections from "Planned" sections so the next agent knows what exists vs what'\''s designed but not built.

4. If something is impossible to implement or has conflicting instructions, research current practices and fix the discrepancy — but preserve the design intent.

5. Never remove cross-references between specs, even to planned sections — mark them as "(Planned)" instead.

When you are done, ensure you have added at least one (1) new todo to the kanban.'

usage() {
  cat <<'USAGE'
Usage: ralph [prompt] [max_runs] [options]
       ralph taskq <subcommand> [args]

Arguments:
  prompt       The prompt to send each loop (default: built-in /tackle prompt)
  max_runs     Max iterations (default: unlimited). Can be first arg if numeric.

Options:
  -d, --dir <path>     Working directory (default: current dir)
  -m, --model <model>  Model to use (default: opus)
  -n, --name <name>    Name this ralph instance (default: auto-generated)
  --cli <harness>       CLI harness: claude|codex|gemini|opencode (default: claude)
  --marathon            Enable rate-limit detection with 30min sleep
  --no-log              Disable log files (output to terminal only)
  -h, --help            Show this help

Task board:
  taskq                 Cross-repo task board query/update utility

Examples:
  ralph 10                                          # 10 runs with default prompt
  ralph "See AGENT_PROMPT.md" 10                    # Custom prompt, 10 runs
  ralph "Fix all lint errors" -d ~/my-project -n lint-fixer
  ralph --marathon                                  # Infinite with rate-limit recovery
  ralph taskq next                                  # Pick next actionable task
  ralph taskq task TASK-004a                        # Show task details
  ralph taskq set-status TASK-004a in_progress      # Update task status
USAGE
  exit 0
}

# --- Parse args ---
PROMPT=""
MAX_RUNS=0
WORK_DIR=""
MODEL="opus"
CLI_BIN="claude"
RALPH_NAME=""
MARATHON=false
NO_LOG=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -d|--dir) WORK_DIR="$2"; shift 2 ;;
    -m|--model) MODEL="$2"; shift 2 ;;
    --cli) CLI_BIN="$2"; shift 2 ;;
    -n|--name) RALPH_NAME="$2"; shift 2 ;;
    --marathon) MARATHON=true; shift ;;
    --no-log) NO_LOG=true; shift ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      # If first positional is a number and no prompt yet, treat as max_runs (use default prompt)
      if [ -z "$PROMPT" ] && [[ "$1" =~ ^[0-9]+$ ]]; then
        MAX_RUNS="$1"
        PROMPT="$DEFAULT_PROMPT"
      elif [ -z "$PROMPT" ]; then
        PROMPT="$1"
      elif [ "$MAX_RUNS" -eq 0 ] 2>/dev/null && [[ "$1" =~ ^[0-9]+$ ]]; then
        MAX_RUNS="$1"
      else
        echo "Unexpected argument: $1"
        usage
      fi
      shift
      ;;
  esac
done

# Normalize common Codex model aliases to canonical names.
if [[ "$CLI_BIN" == "codex" ]]; then
  MODEL_LOWER="$(printf '%s' "$MODEL" | tr '[:upper:]' '[:lower:]')"
  case "$MODEL_LOWER" in
    "gpt 5.4"|"gpt5.4")
      MODEL="gpt-5.4"
      ;;
    "gpt 5.3"|"gpt5.3")
      MODEL="gpt-5.3"
      ;;
    "gpt 4.1"|"gpt4.1")
      MODEL="gpt-4.1"
      ;;
    "o4 mini"|"o4mini")
      MODEL="o4-mini"
      ;;
  esac
fi

# Use default prompt if none provided
if [ -z "$PROMPT" ]; then
  PROMPT="$DEFAULT_PROMPT"
fi

# --- Setup ---
RALPH_DIR="$HOME/.ralph"
LOG_DIR="$RALPH_DIR/logs"
PID_DIR="$RALPH_DIR/pids"
mkdir -p "$LOG_DIR" "$PID_DIR"

if [ -z "$RALPH_NAME" ]; then
  RALPH_NAME="ralph-$(date +%Y%m%d-%H%M%S)-$$"
fi

LOG_FILE="$LOG_DIR/${RALPH_NAME}.log"
PID_FILE="$PID_DIR/${RALPH_NAME}.pid"
META_FILE="$PID_DIR/${RALPH_NAME}.meta"
RATE_LIMIT_SLEEP=1800

# Write PID file
echo $$ > "$PID_FILE"

# Write metadata
cat > "$META_FILE" <<EOF
name=$RALPH_NAME
pid=$$
prompt=$PROMPT
max_runs=$MAX_RUNS
current_run=0
model=$MODEL
cli=$CLI_BIN
work_dir=${WORK_DIR:-$(pwd)}
marathon=$MARATHON
started=$(date -Iseconds)
EOF

log() {
  local msg="[$(date '+%H:%M:%S')] $1"
  if [ "$NO_LOG" = false ]; then
    echo "$msg" | tee -a "$LOG_FILE"
  else
    echo "$msg"
  fi
}

cleanup() {
  # Prevent re-entry from repeated Ctrl-C
  trap - INT TERM
  log "🛑 Ralph '$RALPH_NAME' stopped after $RUN_COUNT runs."
  rm -f "$PID_FILE"
  # Kill child processes only (not ourselves)
  pkill -TERM -P $$ 2>/dev/null
  wait 2>/dev/null
  exit 0
}

trap cleanup INT TERM

# Change to working directory if specified
if [ -n "$WORK_DIR" ]; then
  cd "$WORK_DIR" || { echo "Error: cannot cd to $WORK_DIR"; exit 1; }
fi

log "🚀 Ralph '$RALPH_NAME' started (cli=$CLI_BIN, model=$MODEL, max_runs=$MAX_RUNS, dir=$(pwd))"
log "📝 Prompt: ${PROMPT:0:120}$([ ${#PROMPT} -gt 120 ] && echo '...')"
[ "$NO_LOG" = false ] && log "📄 Log: $LOG_FILE"

RUN_COUNT=0

while true; do
  RUN_COUNT=$((RUN_COUNT + 1))

  if [ "$MAX_RUNS" -gt 0 ] && [ "$RUN_COUNT" -gt "$MAX_RUNS" ]; then
    log "✅ Reached max runs ($MAX_RUNS). Stopping."
    break
  fi

  log "--- RUN $RUN_COUNT$([ "$MAX_RUNS" -gt 0 ] && echo "/$MAX_RUNS") ---"

  # Update meta with current run
  sed -i "s/^current_run=.*/current_run=$RUN_COUNT/" "$META_FILE" 2>/dev/null \
    || echo "current_run=$RUN_COUNT" >> "$META_FILE"

  OUTPUT_TMP=$(mktemp)
  JQ_FILTER='
    if .type == "assistant" then
      .message.content[]? |
      if .type == "text" then
        "💬 " + .text
      elif .type == "tool_use" then
        "🔧 " + .name + ": " + (.input | tostring | .[0:150])
      else empty end
    elif .type == "user" then
      .message.content[]? |
      if .type == "tool_result" then
        "📋 " + (.content | tostring | .[0:200])
      else empty end
    else empty end
  '
  CODEX_JQ_FILTER='
    fromjson? |
    if . == null then
      empty
    elif .type == "item.completed" and (.item.type // "") == "agent_message" then
      "💬 " + (.item.text // "")
    elif .type == "item.completed" and (.item.type // "") == "command_execution" then
      ("🔧 " + ((.item.command // "") | gsub("\\s+"; " ") | .[0:150])),
      (if (((.item.aggregated_output // "") | gsub("\\s+"; " ")) | length) > 0 then
         "📋 " + (((.item.aggregated_output // "") | gsub("\\s+"; " ")) | .[0:200])
       else
         empty
       end)
    elif .type == "error" then
      "⚠️ " + ((.message // "") | .[0:300])
    elif .type == "turn.failed" then
      "⚠️ " + ((.error.message // "") | .[0:300])
    else
      empty
    end
  '
  case "$CLI_BIN" in
    claude)
      claude -p --model="$MODEL" --dangerously-skip-permissions \
        "$PROMPT" \
        --print --output-format=stream-json --verbose </dev/null 2>/dev/null \
      | jq --unbuffered -r "$JQ_FILTER" \
      | if [ "$NO_LOG" = false ]; then tee -a "$LOG_FILE" "$OUTPUT_TMP"; else tee "$OUTPUT_TMP"; fi
      ;;
    codex)
      codex exec --dangerously-bypass-approvals-and-sandbox --json --model "$MODEL" "$PROMPT" </dev/null 2>&1 \
      | jq --unbuffered -Rr "$CODEX_JQ_FILTER" \
      | if [ "$NO_LOG" = false ]; then tee -a "$LOG_FILE" "$OUTPUT_TMP"; else tee "$OUTPUT_TMP"; fi
      ;;
    gemini)
      gemini --model "$MODEL" "$PROMPT" </dev/null 2>/dev/null \
      | if [ "$NO_LOG" = false ]; then tee -a "$LOG_FILE" "$OUTPUT_TMP"; else tee "$OUTPUT_TMP"; fi
      ;;
    opencode)
      opencode run "$PROMPT" --model "$MODEL" </dev/null 2>/dev/null \
      | if [ "$NO_LOG" = false ]; then tee -a "$LOG_FILE" "$OUTPUT_TMP"; else tee "$OUTPUT_TMP"; fi
      ;;
    *)
      log "⚠️  Unknown harness '$CLI_BIN', falling back to claude"
      claude -p --model="$MODEL" --dangerously-skip-permissions \
        "$PROMPT" \
        --print --output-format=stream-json --verbose </dev/null 2>/dev/null \
      | jq --unbuffered -r "$JQ_FILTER" \
      | if [ "$NO_LOG" = false ]; then tee -a "$LOG_FILE" "$OUTPUT_TMP"; else tee "$OUTPUT_TMP"; fi
      ;;
  esac
  OUTPUT=$(<"$OUTPUT_TMP")
  rm -f "$OUTPUT_TMP"

  log "--- RUN $RUN_COUNT COMPLETE ---"

  # Check for errors
  if echo "$OUTPUT" | grep -q "You've hit your limit"; then
    if [ "$MARATHON" = true ]; then
      log "⏳ Rate limited. Sleeping 30 minutes..."
      sleep "$RATE_LIMIT_SLEEP" &
      wait $!
    else
      log "⚠️  Rate limited. Use --marathon to auto-retry. Stopping."
      break
    fi
  elif echo "$OUTPUT" | grep -qi "error\|fatal\|panic"; then
    log "⚠️  Possible error detected in output (continuing anyway)"
  fi

  sleep 2 &
  wait $!
done

cleanup
